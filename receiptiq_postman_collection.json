        {
          "name": "Register User (Better Auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/sign-up/email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "sign-up",
                "email"
              ]
            }
          }
        },
        {
          "name": "Login User (Better Auth)",
